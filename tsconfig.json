{
  "compilerOptions": {
    "baseUrl": ".",
    
    "outDir": "dist",
    "module": "esnext",
    "target": "es6",
    "lib": ["es2017", "dom", "scripthost"],
    "sourceMap": true,
    "allowJs": true,
    "jsx": "react",
    "moduleResolution": "node",
    "rootDir": "src",
    "noImplicitReturns": true,
    "noImplicitThis": false,
    "noImplicitAny": false,
    "importHelpers": true,
    "downlevelIteration": true,
    "suppressImplicitAnyIndexErrors": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "paths": {
      "igniteui-core/*": ["src/ig/igniteui-core/*"],
      "igniteui-core": ["src/ig/igniteui-core"],
      "igniteui-data-grids/*": ["src/ig/igniteui-data-grids/*"],
      "igniteui-data-grids": ["src/ig/igniteui-data-grids"],
      "igniteui-charts/*": ["src/ig/igniteui-charts/*"],
      "igniteui-charts": ["src/ig/igniteui-charts"],
      "igniteui-layouts/*": ["src/ig/igniteui-layouts/*"],
      "igniteui-layouts": ["src/ig/igniteui-layouts"],
      "igniteui-inputs/*": ["src/ig/igniteui-inputs/*"],
      "igniteui-inputs": ["src/ig/igniteui-inputs"],
      "igniteui-excel/*": ["src/ig/igniteui-excel/*"],
      "igniteui-excel": ["src/ig/igniteui-excel"],
      "igniteui-spreadsheet/*": ["src/ig/igniteui-spreadsheet/*"],
      "igniteui-spreadsheet": ["src/ig/igniteui-spreadsheet"],
      "igniteui-spreadsheet-chart-adapter/*": ["src/ig/igniteui-spreadsheet-chart-adapter/*"],
      "igniteui-spreadsheet-chart-adapter": ["src/ig/igniteui-spreadsheet-chart-adapter"],
      "igniteui-react-core/ES5/*": ["src/ig/igniteui-core/*"],
      "igniteui-datasources/*": ["src/ig/igniteui-datasources/*"],
      "igniteui-datasources": ["src/ig/igniteui-datasources"],
      "igniteui-webinputs/*": ["src/ig/igniteui-webinputs/*"],
      "igniteui-webinputs": ["src/ig/igniteui-webinputs"],
      "igniteui-webgrids/*": ["src/ig/igniteui-webgrids/*"],
      "igniteui-webgrids": ["src/ig/igniteui-webgrids"],
      "igniteui-dashboards/*": ["src/ig/igniteui-dashboards/*"],
      "igniteui-dashboards": ["src/ig/igniteui-dashboards"],
      "igniteui-gauges/*": ["src/ig/igniteui-gauges/*"],
      "igniteui-gauges": ["src/ig/igniteui-gauges"],
      "igniteui-maps/*": ["src/ig/igniteui-maps/*"],
      "igniteui-maps": ["src/ig/igniteui-maps"]
    }
  },
  "exclude": [
    "node_modules",
    "build",
    "scripts",
    "acceptance-tests",
    "webpack",
    "jest",
    "src/setupTests.ts",
    "gulpfile.js"
  ]
}
